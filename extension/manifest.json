{
  "manifest_version": 2,
  "name": "Airbnb Archiver (Beta)",
  "version": "0.1.1",
  "description": "BETA — still undergoing testing. Archive Airbnb listings so they stop reappearing on the map and in results, plus star/maybe lists for the ones you're considering.",
  "browser_specific_settings": {
    "gecko": {
      "id": "airbnb-archiver@noam.local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "storage",
    "webRequest",
    "webRequestBlocking",
    "*://*.airbnb.com/*"
  ],
  "background": {
    "scripts": [
      "filter.js",
      "background.js"
    ],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.airbnb.com/*"
      ],
      "js": [
        "store.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg"
  },
  "browser_action": {
    "default_title": "Airbnb Archiver",
    "default_popup": "popup.html",
    "default_icon": "icon.svg"
  }
}
